{
  "displayName": "Homebridge Kwikset",
  "name": "homebridge-kwikset",
  "version": "0.1.1",
  "description": "Homebridge plugin for Kwikset Halo Wi-Fi smart locks via the Kwikset cloud API.",
  "author": "Dan Short <44993+danshort@users.noreply.github.com>",
  "license": "MIT",
  "homepage": "https://github.com/danshort/homebridge-kwikset#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danshort/homebridge-kwikset.git"
  },
  "bugs": {
    "url": "https://github.com/danshort/homebridge-kwikset/issues"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "files": [
    "dist",
    "homebridge-ui",
    "config.schema.json"
  ],
  "engines": {
    "node": ">=18.0.0",
    "homebridge": ">=1.6.0"
  },
  "keywords": [
    "homebridge-plugin",
    "kwikset",
    "halo",
    "lock",
    "smart-lock"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "watch": "tsc -w",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^1.0.3",
    "amazon-cognito-identity-js": "^6.3.18"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "hap-nodejs": "0.14.3",
    "homebridge": "^1.8.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "homebridge": ">=1.6.0"
  }
}
